#!name = 𝑽𝑷𝑺
#!desc = 监控VPS流量信息和处理器、内存占用情况
#!category = 𝑷𝒂𝒏𝒆𝒍
#!author = 整点猫咪
#!howto = 将模块内容复制到本地后根据自己VPS IP地址及端口修改 http://127.0.0.1:7122/traffic 部分进行使用ddl=后面接你的VPS到期时间，total=输入你的VPS每月流量数目

[Panel]
𝙋𝙚𝙚𝙠𝙖𝙗𝙤 = script-name= 𝙋𝙚𝙚𝙠𝙖𝙗𝙤,update-interval=3600
𝙍𝙁𝘾𝙃𝙤𝙨𝙩 = script-name= 𝙍𝙁𝘾𝙃𝙤𝙨𝙩,update-interval=3600
𝘿𝙈𝙄𝙏 = script-name= 𝘿𝙈𝙄𝙏,update-interval=3600

[Script]
𝙋𝙚𝙚𝙠𝙖𝙗𝙤 = type=generic,script-path=https://raw.githubusercontent.com/JupiterH/Surge/main/Scripts/VPS.js, argument = url=http://157.254.32.57:7122&name=🇭🇰 𝙋𝙚𝙚𝙠𝙖𝙗𝙤&icon=party.popper
𝙍𝙁𝘾𝙃𝙤𝙨𝙩 = type=generic,script-path=https://raw.githubusercontent.com/JupiterH/Surge/main/Scripts/VPS.js, argument = url=http://82.40.33.139:7122&name=🇯🇵 𝙍𝙁𝘾𝙃𝙤𝙨𝙩&icon=party.popper
𝘿𝙈𝙄𝙏 = type=generic,script-path=https://raw.githubusercontent.com/JupiterH/Surge/main/Scripts/VPS.js, argument = url=http://64.186.243.62:7122&name=🇺🇸 𝘿𝙈𝙄𝙏&icon=party.popper
